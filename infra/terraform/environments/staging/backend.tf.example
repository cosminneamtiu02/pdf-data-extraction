# Uncomment and configure for your cloud provider's state backend.
#
# Example for AWS S3:
# terraform {
#   backend "s3" {
#     bucket = "your-project-tfstate-staging"
#     key    = "staging/terraform.tfstate"
#     region = "us-east-1"
#   }
# }
#
# Example for GCP GCS:
# terraform {
#   backend "gcs" {
#     bucket = "your-project-tfstate-staging"
#     prefix = "staging"
#   }
# }
