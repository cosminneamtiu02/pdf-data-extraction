# =====================================================================
# Local-dev template for apps/backend/.env. DO NOT deploy verbatim.
#
# In prod, values come from deployment secrets and the environment
# overrides declared in `infra/compose/docker-compose.prod.yml` (e.g.
# `CORS_ORIGINS=${CORS_ORIGINS:-[]}`, `APP_ENV=production`). Keys below
# tagged `# dev-only` ship with localhost / Docker-host addresses baked
# in and MUST be overridden in prod per your trust model; copying this
# file to `.env` inside a containerized prod deployment without
# overrides will silently allow `http://localhost:5173` as a CORS
# origin and point Ollama at the developer's machine via the Docker
# host mapping. See issue #415.
#
# Note on `# dev-only` markers: they are written on their own comment
# line above each assignment, NOT as trailing comments after `KEY=VALUE`.
# Some dotenv consumers (Docker Compose `--env-file`, for instance)
# treat everything to the right of `=` as part of the value, which
# would corrupt JSON-ish values like `CORS_ORIGINS=[...]`.
# =====================================================================

# Optional (defaults exist in code)
# dev-only — override in prod to `production`.
# APP_ENV accepts exactly one of: development, production, testing
# (case-sensitive). A typo like "Production" or "prod" fails at startup
# with a Pydantic ValidationError — see issue #370. The "production" value
# is what the app keys off to disable /docs, /redoc, /openapi.json and
# switch logging to JSON output. Any other valid value leaves /docs,
# /redoc, and /openapi.json enabled, and logging stays non-JSON.
APP_ENV=development
LOG_LEVEL=info
# dev-only — override in prod to your trusted origin allowlist
# (never `["*"]` with credentials).
CORS_ORIGINS=["http://localhost:5173"]
# CORS methods the API accepts as cross-origin requests. Defaults to the
# actual route surface (GET for /health, /ready, /openapi.json; POST for
# /api/v1/extract). Narrow further in deployments that need it; do NOT
# widen to ["*"] with allow_credentials=true.
CORS_METHODS=["GET","HEAD","POST"]
# CORS request-headers the API accepts. Defaults to the narrow allowlist the
# application actually consumes. Widen explicitly in deployments that send
# additional headers; again, do NOT fall back to ["*"] with credentials.
CORS_HEADERS=["Authorization","Content-Type","X-Request-Id"]
# Whether the CORS middleware advertises ``Access-Control-Allow-Credentials:
# true``. Defaults to ``false`` because this service has no cookie or
# session authentication — opting in is extra attack surface for no
# functional gain. Setting this to ``true`` alongside ``CORS_ORIGINS=["*"]``
# is rejected at startup: the CORS spec forbids credentialed responses to
# wildcarded origins. Issue #346.
CORS_ALLOW_CREDENTIALS=false
# Maximum string length for a single structlog *value* before the redaction
# filter truncates it (the top-level `event` value is preserved; key names are
# not affected). Protects against accidentally logging huge payloads (PDF
# bytes, model responses). Defaults to 500.
LOG_MAX_VALUE_LENGTH=500
# JSON array of log-record keys that the redaction filter strips from the
# event dict entirely (the key and its value are removed, not replaced with a
# placeholder). Match is case-insensitive and applies at any depth inside
# nested dicts/lists. Guards sensitive fields (raw PDF bytes, extracted user
# data, LLM prompts) from appearing in logs.
LOG_REDACTED_KEYS=["pdf_bytes","raw_output","extracted_value","prompt","field_values"]
STRUCTURED_OUTPUT_MAX_RETRIES=3
# Relative to the process cwd; `task dev:backend` runs from apps/backend/.
# dev-only — the prod compose file sets SKILLS_DIR=/app/skills (an absolute
# path under the container WORKDIR `/app`, and the expected bind-mount
# target) and bind-mounts operator-supplied skills over it. Leaving this
# relative path inside a container works only because the Dockerfile
# WORKDIR happens to align with it; override explicitly in prod.
SKILLS_DIR=skills
DOCLING_OCR_DEFAULT=auto
DOCLING_TABLE_MODE_DEFAULT=fast
# Maximum PDF page count. Parser rejects larger PDFs with PDF_TOO_MANY_PAGES (413)
# before running OCR or layout analysis. Defaults to 200.
MAX_PDF_PAGES=200
# Maximum upload byte size. Router rejects uploads exceeding this before
# PDF parsing (Docling) is allocated. The multipart form is still parsed
# by Starlette; this guard prevents the expensive downstream pipeline.
# Defaults to 50 MB (52428800 bytes).
MAX_PDF_BYTES=52428800

# Ollama LLM backend (PDFX-E004-F002)
# dev-only — `host.docker.internal` resolves either via Docker Desktop
# (Mac/Windows, automatic) or via this repo's Compose `host-gateway`
# mapping on Linux (see `infra/compose/docker-compose*.yml`), letting a
# containerized backend reach an Ollama running on the developer's
# machine. In prod, override to the in-cluster Ollama service URL (or
# the `https://` endpoint of your managed LLM host).
OLLAMA_BASE_URL=http://host.docker.internal:11434
# For non-containerized dev loops, use:
# OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_SECONDS=30.0
# Sampling temperature forwarded to Ollama's /api/generate baseline
# (issue #384). Range 0.0-2.0 matches Ollama's advertised domain; values
# outside the range are rejected at Settings construction. Default 0.0
# preserves deterministic sampling for StructuredOutputValidator retries
# (issue #136). Raise above 0.0 only when a skill deliberately wants
# creative-mode outputs (e.g. inferred descriptions).
OLLAMA_TEMPERATURE=0.0
# Readiness probe TTL in seconds. The /ready endpoint caches probe results
# for this duration before re-probing Ollama. 0 disables caching (every
# /ready call probes). Defaults to 10.
OLLAMA_PROBE_TTL_SECONDS=10.0
# HTTP timeout for the readiness probe against Ollama /api/tags.
# Separate from OLLAMA_TIMEOUT_SECONDS (which covers /api/generate).
OLLAMA_PROBE_TIMEOUT_SECONDS=5.0

# Extraction pipeline (PDFX-E006-F002)
# End-to-end timeout for the full extraction pipeline in seconds.
# Covers parsing + extraction + coordinate resolution + annotation.
EXTRACTION_TIMEOUT_SECONDS=180.0

# Extraction admission control (issue #109)
# Maximum number of concurrent extraction pipelines per process. Over-limit
# requests are rejected immediately with HTTP 503 (EXTRACTION_OVERLOADED)
# rather than queued, so callers do not wait behind their own 504 budget.
# Tune to (roughly) available CPU cores for Docling + Ollama parallelism.
MAX_CONCURRENT_EXTRACTIONS=4

# Benchmark CLI (scripts/benchmark.py, issue #237)
# These knobs configure the local latency benchmark. They are read through
# ``BenchmarkSettings`` (env_prefix=BENCH_), not the main ``Settings`` class,
# because they are operator-facing CLI knobs rather than app-runtime config.
# Explicit --flag arguments on the benchmark command still win over these.
# The benchmark targets a locally-running service; these defaults are
# dev-only by construction — the CLI is not meant to run against prod.
BENCH_URL=http://localhost:8000
BENCH_ITERATIONS=10
# dev-only — relative to the operator cwd.
BENCH_FIXTURES_DIR=fixtures/bench
BENCH_SKILL_NAME=invoice
BENCH_SKILL_VERSION=1
# Optional PID of the running service process (for NFR-008 RSS measurement);
# leave empty or unset to skip service-side memory reporting.
BENCH_SERVICE_PID=
# Number of warm-up requests to discard per fixture x mode batch before
# timing begins. 0 disables warm-up.
BENCH_WARMUP=1
# HTTP request timeout in seconds for each extraction call. Must be > 0.
BENCH_TIMEOUT=300
